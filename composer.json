{
    "name": "chenasraf/latch",
    "description": "Cross-package hook/filter registry system for PHP",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Chen Asraf"
        }
    ],
    "require": {
        "php": "^8.2"
    },
    "require-dev": {
        "pestphp/pest": "^2.0",
        "phpstan/phpstan": "^1.10",
        "laravel/pint": "^1.0"
    },
    "autoload": {
        "psr-4": {
            "Latch\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Latch\\Tests\\": "tests/"
        }
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Latch\\Integration\\Laravel\\LatchServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
